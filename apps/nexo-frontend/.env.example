# ─── Firebase (requerido) ─────────────────────────────────────────────────────
# Obtener desde: Firebase Console → Configuración del proyecto → Tus apps → SDK Config
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=nexo-familia.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nexo-familia
VITE_FIREBASE_STORAGE_BUCKET=nexo-familia.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Backend Python FastAPI (opcional — para Copiloto IA, Scanner y Analytics) ─
# En desarrollo: http://localhost:8001
# En producción: URL de Railway / Render / VPS
VITE_NEXO_BACKEND_URL=http://localhost:8001

# ─── Backend Node.js (opcional — para Radar Judicial) ────────────────────────
# En desarrollo: http://localhost:3001
VITE_NEXO_NODE_URL=http://localhost:3001
