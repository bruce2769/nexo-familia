# ============================================================
# NEXO BACKEND (Python/FastAPI) — Variables de entorno
# Copia como .env y rellena los valores reales
# ⚠️  NUNCA subas este archivo a Git con valores reales
# ============================================================

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Firebase Admin SDK ────────────────────────────────────────
# JSON del service account EN UNA SOLA LÍNEA (sin saltos de línea)
# Usa el script format_firebase_key.py para convertirlo
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── CORS ─────────────────────────────────────────────────────
# Separados por coma, sin espacios
ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app

# ── Frontend URL (para Stripe/MP redirect) ────────────────────
FRONTEND_URL=http://localhost:5173

# ── Base de datos ─────────────────────────────────────────────
# Railway PostgreSQL addon lo inyecta automáticamente como DATABASE_URL
# En local, si no está → usa SQLite (causas_judiciales.db)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Pagos (opcional) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
MERCADOPAGO_ACCESS_TOKEN=TEST-...

# ── Rate limiting ─────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=20
MAX_IA_REQUESTS_PER_DAY=20
