rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para la colección users
    match /users/{userId} {
      // El usuario solo puede leer su propio documento de créditos
      allow read: if request.auth != null && request.auth.uid == userId;
      // BLOQUEO TOTAL de escrituras desde el cliente
      // Solo el backend (FastAPI usnado Admin SDK) puede modificar créditos
      allow write: if false;
      
      // Subcolección de transacciones
      match /transactions/{transactionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }
    
    // Reglas para el historial de documentos
    match /escritos/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false;
    }
    
    // Causas consultadas (opcional dependiendo si guardas local o en la nube)
    match /causas/{causaId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false; // Solo se guardan vía backend
    }
  }
}
