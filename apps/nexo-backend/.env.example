# ============================================================
# NEXO BACKEND (Python/FastAPI) — Variables de entorno
# Copia como .env y rellena los valores reales
# ⚠️  NUNCA subas este archivo a Git
# ============================================================

# ── Firebase Admin SDK ────────────────────────────────────────
# Producción (cloud): JSON en una sola línea, sin saltos
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"nexo-familia",...}
#
# Dev local: dejar vacío → auth omitida automáticamente en modo dev
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Ollama ────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# ── CORS (separados por coma, sin espacios) ───────────────────
# Producción: añadir la URL de Vercel
ALLOWED_ORIGINS=http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=20
