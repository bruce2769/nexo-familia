# ============================================================
# NEXO BACKEND (Python/FastAPI) — Variables de entorno
# Copia como .env y rellena los valores reales
# ⚠️  NUNCA subas este archivo a Git
# ============================================================

# ── Firebase Admin SDK ────────────────────────────────────────
# JSON en UNA sola línea (usa format_firebase_key.py para generarlo)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── CORS (separados por coma, sin espacios) ───────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app

# ── Rate limiting ─────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=20
MAX_IA_REQUESTS_PER_DAY=20
