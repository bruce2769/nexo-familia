# Variables de Entorno - NEXO BACKEND
# Copia este archivo como .env y rellena los valores reales

# ============================================================
# FIREBASE ADMIN SDK
# Descarga tu serviceAccountKey.json desde Firebase Console >
# Configuración del proyecto > Cuentas de servicio
# ============================================================
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_DATABASE_URL=https://tu-proyecto.firebaseio.com

# ============================================================
# SERVIDOR
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# PJUD SCRAPER CONFIG
# ============================================================
# Intervalo del cron job (por defecto: cada 6 horas)
# Formato cron estándar: minuto hora día-mes mes día-semana
CRON_SCHEDULE=0 */6 * * *

# User-Agent a usar (puedes rotarlos para evitar bloqueos)
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Delay mínimo y máximo entre requests (en milisegundos)
MIN_DELAY_MS=3000
MAX_DELAY_MS=8000

# ============================================================
# SCRAPER — Modo de operación
# "api"       → Usa endpoints REST del PJUD (más rápido, puede romperse)
# "playwright"→ Usa navegador real (más robusto, más lento)
# ============================================================
SCRAPER_MODE=api

# ============================================================
# NOTIFICACIONES (Opcional - Pilar 2 integración futura)
# ============================================================
OPENAI_API_KEY=sk-...
